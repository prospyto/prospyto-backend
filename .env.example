DATABASE_URL=postgres://user:password@host:5432/prospyto
PORT=4000

# Auth admin (JWT)
JWT_SECRET=remplace_par_une_chaine_aleatoire_longue_et_unique
ADMIN_EMAIL=ton-email@exemple.com
# Hash bcrypt du mot de passe admin. Génère le tien avec:
# node -e "console.log(require('bcryptjs').hashSync('TON_MOT_DE_PASSE', 10))"
ADMIN_PASSWORD_HASH=$2b$10$remplace_par_ton_propre_hash

# Email transactionnel (Resend - https://resend.com)
# Sans domaine vérifié, Resend n'autorise l'envoi qu'à l'adresse de ton
# compte Resend (mode bac à sable). Vérifie un domaine sur
# resend.com/domains pour envoyer à tes vrais clients, puis mets à jour
# EMAIL_FROM en conséquence.
RESEND_API_KEY=re_remplace_par_ta_cle
EMAIL_FROM=Prospère <onboarding@resend.dev>
# Utilisé pour construire le lien de suivi dans l'email "projet lancé"
FRONTEND_URL=https://prospyto.dev
